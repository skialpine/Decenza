{
    "title": "I got your back",
    "author": "Decent",
    "beverage_type": "espresso",
    "notes": "The goal of this profile is to never fail to make an acceptable espresso, at any grinder dial setting. The profile detects the resistance by looking at the pressure. It then either it transitions to a flat 2.2ml/s flow shot at the low resistance (low pressure) or to bloom at the high resistance (high pressure/low flow rate).  Profile created by Shin.",
    "legacy_profile_type": "settings_2c",
    "version": "2",
    "number_of_preinfuse_frames": 2,
    "maximum_pressure": 0.0,
    "maximum_flow": 0.0,
    "minimum_pressure": 4.0,
    "target_weight": 36.0,
    "target_volume": 0,
    "mode": "frame_based",
    "temperature_presets": [
        90,
        90,
        90,
        90
    ],
    "steps": [
        {
            "name": "preinfusion start",
            "temperature": 90.0,
            "sensor": "coffee",
            "pump": "flow",
            "transition": "fast",
            "pressure": 1.0,
            "flow": 4.0,
            "seconds": 2.0,
            "volume": 500.0
        },
        {
            "name": "preinfusion",
            "temperature": 90.0,
            "sensor": "coffee",
            "pump": "flow",
            "transition": "fast",
            "pressure": 1.0,
            "flow": 4.0,
            "seconds": 11.0,
            "volume": 500.0,
            "exit": {
                "type": "pressure",
                "condition": "over",
                "value": 4.0
            }
        },
        {
            "name": "Low Resistance",
            "temperature": 90.0,
            "sensor": "coffee",
            "pump": "flow",
            "transition": "fast",
            "pressure": 1.0,
            "flow": 2.2,
            "seconds": 30.0,
            "volume": 500.0,
            "exit": {
                "type": "pressure",
