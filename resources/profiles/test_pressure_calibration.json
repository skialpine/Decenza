{
    "title": "Test/pressure calibration",
    "author": "Decent",
    "beverage_type": "{calibrate}",
    "notes": "You will need a portafilter fitted with a pressure gauge that leaks or has a slow flow rate.  This profile will slowly rise to 9 bar and hold it.  Compare what is on the screen with what your analog pressure gauge tells you.  Go to Settings->Machine->Calibrate and enter the held pressure value, and then retest until the pressure until the two agree.",
    "legacy_profile_type": "settings_2c",
    "version": "2",
    "number_of_preinfuse_frames": 2,
    "maximum_pressure": 0.0,
    "maximum_flow": 0.0,
    "minimum_pressure": 6.0,
    "target_weight": 36.0,
    "target_volume": 36.0,
    "mode": "frame_based",
    "is_recipe_mode": false,
    "temperature_presets": [
        1,
        1,
        1,
        1
    ],
    "steps": [
        {
            "name": "fast rise",
            "temperature": 1.0,
            "sensor": "coffee",
            "pump": "pressure",
            "transition": "fast",
            "pressure": 7.0,
            "flow": 0.0,
            "seconds": 20.0,
            "volume": 500.0,
            "exit": {
                "type": "pressure",
                "condition": "over",
                "value": 7.0
            }
        },
        {
            "name": "final slow rise",
            "temperature": 1.0,
            "sensor": "coffee",
            "pump": "pressure",
            "transition": "smooth",
            "pressure": 9.0,
            "flow": 0.0,
            "seconds": 3.0,
            "volume": 500.0
        },
        {
            "name": "hold",
            "temperature": 1.0,
            "sensor": "coffee",
            "pump": "pressure",
            "transition": "fast",
            "pressure": 9.0,
            "flow": 0.0,
            "seconds": 60.0,
            "volume": 500.0
        }
    ],
    "espresso_temperature": 1.0,
    "tank_desired_water_temperature": 0.0,
    "espresso_pressure": 9.0,
    "espresso_decline_time": 0.0,
    "espresso_hold_time": 35.0,
    "preinfusion_time": 6.0,
    "preinfusion_stop_pressure": 4.0,
    "preinfusion_flow_rate": 4.5,
    "pressure_end": 6.0,
    "flow_profile_preinfusion": 4.2,
    "flow_profile_preinfusion_time": 6.0,
    "flow_profile_hold": 1.8,
    "flow_profile_hold_time": 0.0,
    "flow_profile_decline": 1.0,
    "flow_profile_decline_time": 23.0,
    "flow_profile_minimum_pressure": 6.0,
    "maximum_pressure_range_advanced": 0.6,
    "maximum_flow_range_advanced": 0.6
}
